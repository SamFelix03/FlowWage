  "workflow": {
    "name": "FlowWage Full E2E - Single Flow",
    "description": "Single end-to-end flow: income signals, XMTP intent, persona gate, superchain swap, base sepolia aave deposit, offramp, and receipts."
  },
  "nodes": [
    { "id": "trigger-1", "type": "trigger", "position": { "x": 0, "y": 220 }, "data": { "label": "Manual Trigger", "type": "trigger", "config": { "triggerType": "Manual" } } },

    { "id": "rf-sub", "type": "action", "position": { "x": 230, "y": 60 }, "data": { "label": "Request Subscribe", "type": "action", "config": { "actionType": "request-finance/subscribe-invoice-events", "webhookUrl": "https://example.com/webhooks/request-finance", "walletAddress": "{{@trigger-1:Manual Trigger.walletAddress}}", "eventTypes": "create,paid" } } },
    { "id": "rf-history", "type": "action", "position": { "x": 460, "y": 60 }, "data": { "label": "Request Payment History", "type": "action", "config": { "actionType": "request-finance/get-payment-history", "take": "10", "skip": "0" } } },
    { "id": "sablier-sub", "type": "action", "position": { "x": 690, "y": 60 }, "data": { "label": "Sablier Subscribe", "type": "action", "config": { "actionType": "sablier/subscribe-to-stream-events", "network": "11155420", "lockupContractAddress": "0x0000000000000000000000000000000000000001", "webhookUrl": "https://example.com/webhooks/sablier", "walletAddress": "{{@trigger-1:Manual Trigger.walletAddress}}" } } },
    { "id": "sablier-state", "type": "action", "position": { "x": 920, "y": 60 }, "data": { "label": "Sablier Stream State", "type": "action", "config": { "actionType": "sablier/get-stream-state", "network": "11155420", "lockupContractAddress": "0x0000000000000000000000000000000000000001", "streamId": "1" } } },
