    { "id": "sf-incoming", "type": "action", "position": { "x": 1380, "y": 60 }, "data": { "label": "Superfluid Incoming", "type": "action", "config": { "actionType": "superfluid/get-incoming-streams", "network": "11155420", "walletAddress": "{{@trigger-1:Manual Trigger.walletAddress}}", "limit": 20 } } },
    { "id": "web3-balance", "type": "action", "position": { "x": 1610, "y": 60 }, "data": { "label": "USDC Balance", "type": "action", "config": { "actionType": "web3/check-token-balance", "network": "11155420", "address": "{{@trigger-1:Manual Trigger.walletAddress}}", "tokenConfig": "{\"mode\":\"custom\",\"customToken\":{\"address\":\"0x5fd84259d66cd46123540766be93dfe6d43130d7\",\"symbol\":\"USDC\"}}" } } },
    { "id": "xmtp-sub", "type": "action", "position": { "x": 1840, "y": 60 }, "data": { "label": "XMTP Subscribe Inbox", "type": "action", "config": { "actionType": "xmtp/subscribe-to-inbox", "webhookUrl": "https://example.com/webhooks/xmtp", "whitelistSenders": "0x1111111111111111111111111111111111111111", "pollIntervalSeconds": "30", "xmtpEnv": "testnet" } } },

    { "id": "xmtp-parse", "type": "action", "position": { "x": 2070, "y": 220 }, "data": { "label": "Parse XMTP Intent", "type": "action", "config": { "actionType": "xmtp/parse-payment-intent", "messageBody": "{\"type\":\"payment\",\"amount\":500,\"token\":\"USDC\",\"chain\":\"op-sepolia\",\"recipient\":\"0x1111111111111111111111111111111111111111\"}" } } },
    { "id": "alloc", "type": "action", "position": { "x": 2300, "y": 220 }, "data": { "label": "Compute Allocation", "type": "action", "config": { "actionType": "code/run-code", "code": "const amount = Number({{@xmtp-parse:Parse XMTP Intent.intent.amount}} ?? 500);\nconst liquid = Number((amount*0.3).toFixed(2));\nconst yieldAmt = Number((amount*0.4).toFixed(2));\nconst convert = Number((amount*0.3).toFixed(2));\nreturn { amount, liquid, yield: yieldAmt, convert, chain: 'op-sepolia', token: 'USDC' };" } } },
    { "id": "convert-check", "type": "action", "position": { "x": 2530, "y": 220 }, "data": { "label": "Convert Bucket > 0", "type": "action", "config": { "actionType": "Condition", "condition": "{{@alloc:Compute Allocation.result.convert}} > 0", "conditionConfig": { "group": { "id": "convert-gate", "logic": "AND", "rules": [ { "id": "convert-rule", "operator": ">", "leftOperand": "{{@alloc:Compute Allocation.result.convert}}", "rightOperand": "0" } ] } } } } },

    { "id": "persona-status", "type": "action", "position": { "x": 2760, "y": 140 }, "data": { "label": "Persona Status", "type": "action", "config": { "actionType": "persona/check-verification-status", "referenceId": "flowwage-user-003" } } },
