    { "id": "persona-approved", "type": "action", "position": { "x": 3680, "y": 140 }, "data": { "label": "Persona Approved?", "type": "action", "config": { "actionType": "Condition", "condition": "{{@persona-status:Persona Status.status}} == \"approved\"", "conditionConfig": { "group": { "id": "persona-approved", "logic": "AND", "rules": [ { "id": "persona-approved-rule", "operator": "=", "leftOperand": "{{@persona-status:Persona Status.status}}", "rightOperand": "approved" } ] } } } } },
    { "id": "persona-create", "type": "action", "position": { "x": 3910, "y": 300 }, "data": { "label": "Create Persona Inquiry", "type": "action", "config": { "actionType": "persona/create-inquiry", "referenceId": "flowwage-user-003", "inquiryTemplateId": "itmpl_A41AqAmnmHDJ7Rm6Q3ur1BbnaEwwXe" } } },
    { "id": "xmtp-kyc", "type": "action", "position": { "x": 4140, "y": 300 }, "data": { "label": "Send KYC Link", "type": "action", "config": { "actionType": "xmtp/send-message", "recipientAddress": "{{@xmtp-parse:Parse XMTP Intent.intent.recipient}}", "message": "KYC required. Complete here: {{@persona-create:Create Persona Inquiry.inquiryUrl}}" } } },

    { "id": "off-corridors", "type": "action", "position": { "x": 3910, "y": 60 }, "data": { "label": "Offramp Corridors", "type": "action", "config": { "actionType": "offramp/get-supported-corridors", "providerMode": "auto", "networkMode": "testnet", "countryCode": "NG" } } },
    { "id": "off-quote", "type": "action", "position": { "x": 4140, "y": 60 }, "data": { "label": "Offramp Quote", "type": "action", "config": { "actionType": "offramp/get-best-quote", "providerMode": "auto", "networkMode": "testnet", "fiatCurrency": "NGN", "cryptoCurrency": "USDC", "amount": "{{@alloc:Compute Allocation.result.convert}}", "countryCode": "NG", "network": "optimism" } } },
    { "id": "off-rate", "type": "action", "position": { "x": 4370, "y": 60 }, "data": { "label": "Offramp Rate History", "type": "action", "config": { "actionType": "offramp/get-rate-history", "cryptoCurrency": "USDC", "fiatCurrency": "NGN", "days": "7" } } },
    { "id": "rate-window", "type": "action", "position": { "x": 4600, "y": 60 }, "data": { "label": "Rate Good Now?", "type": "action", "config": { "actionType": "Condition", "condition": "true == true", "conditionConfig": { "group": { "id": "rate", "logic": "AND", "rules": [ { "id": "r1", "operator": "=", "leftOperand": "true", "rightOperand": "true" } ] } } } } },

