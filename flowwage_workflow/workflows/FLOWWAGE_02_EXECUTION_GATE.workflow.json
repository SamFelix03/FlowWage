  "nodes": [
    { "id": "trigger-1", "type": "trigger", "position": { "x": 0, "y": 220 }, "data": { "label": "Manual Trigger", "type": "trigger", "config": { "triggerType": "Manual" } } },
    { "id": "xmtp-parse", "type": "action", "position": { "x": 240, "y": 220 }, "data": { "label": "Parse XMTP Intent", "type": "action", "config": { "actionType": "xmtp/parse-payment-intent", "messageBody": "{\"type\":\"payment\",\"amount\":500,\"token\":\"USDC\",\"chain\":\"op-sepolia\",\"recipient\":\"0x1111111111111111111111111111111111111111\"}" } } },
    { "id": "alloc", "type": "action", "position": { "x": 500, "y": 220 }, "data": { "label": "Compute Allocation", "type": "action", "config": { "actionType": "code/run-code", "code": "const amount = Number({{@xmtp-parse:Parse XMTP Intent.intent.amount}} ?? 500);\nconst liquid = Number((amount*0.3).toFixed(2));\nconst yieldAmt = Number((amount*0.4).toFixed(2));\nconst convert = Number((amount*0.3).toFixed(2));\nreturn { amount, liquid, yield: yieldAmt, convert, chain: 'op-sepolia', token: 'USDC' };"} } },
